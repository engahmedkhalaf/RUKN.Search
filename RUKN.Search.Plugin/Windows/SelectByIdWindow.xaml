<Window x:Class="RUKN.Search.Plugin.SelectByIdWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             WindowStyle="None"
             WindowStartupLocation="CenterScreen"
             AllowsTransparency="True"
             Background="{x:Null}"
             mc:Ignorable="d"
             Width="360"
             Height="240"
             Title="RUKN Search"
             ResizeMode="CanResizeWithGrip"
             Topmost="False"
             ShowInTaskbar="True"
             Style="{DynamicResource CustomWindowStyle}">

    <Window.InputBindings>
        <KeyBinding Key="Escape"
                    Command="Close" />
        <KeyBinding Gesture="Enter"
                    Command="Open" />
        <KeyBinding Gesture="F1"
                    Command="Help" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="Close"
                        Executed="Close_Button" />
        <CommandBinding Command="Open"
                        Executed="OkButton_Click" />
        <CommandBinding Command="Help"
                        Executed="Ruknbim_Link" />
    </Window.CommandBindings>

    <Border
        x:Name="MainWindow_Border"
        Background="{DynamicResource BackgroundColor}"
            BorderBrush="Transparent"
            BorderThickness="1,1,1,1"
            CornerRadius="15,15,15,15"
            Margin="10,10,10,0"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect 
                BlurRadius="20"
                Color="Gray"
                Opacity="0.3"
                ShadowDepth="0"
                Direction="0">
            </DropShadowEffect>
        </Border.Effect>

        <Grid Background="Transparent" 
              RenderOptions.BitmapScalingMode="HighQuality" 
              Margin="20">
            <Grid>
                <Button Click="Ruknbim_Link"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="0,-4,0,0"
                        Padding="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <Image Source="/RUKN.Search;component/Resources/SelectByRevitId.png"
                           Height="28"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Button>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right">


                    <Button Style="{DynamicResource TabCloseButtonStyle}"
                            Name="CloseButton"
                            Click="Close_Button" />

                </StackPanel>

            </Grid>

            <TextBox
                     Style="{DynamicResource MainTextBox}" 
                     x:Name="textBox" 
                     Text="Insert Element Id" 
                     Height="36" 
                     Width="280"
                     Padding="12,2,2,2"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Left" 
                     MinWidth="280" 
                     MinHeight="25" 
                     VerticalAlignment="Top" 
                     Margin="0,50,0,0" 
                     HorizontalAlignment="Center"
                     GotFocus="TextBox_GotFocus" 
                     LostFocus="TextBox_LostFocus"/>
 
            <Button Style="{DynamicResource ApplyButtonStyle}" 
                    x:Name="applyButton" 
                    Content="Select" 
                    HorizontalAlignment="Center" 
                    Margin="0,105,0,0" 
                    Width="120" 
                    Height="36" 
                    Click="OkButton_Click" 
                    VerticalAlignment="Top"/>




        </Grid>
    </Border>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
</Window>
