<Window x:Class="RUKN.Search.Plugin.ModelProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="{x:Null}"
        mc:Ignorable="d"
        Width="380"
        Height="580"
        Title="By Levels"
        ResizeMode="CanResizeWithGrip"
        Topmost="False"
        ShowInTaskbar="True"
        Style="{DynamicResource CustomWindowStyle}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="Close" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="Close" Executed="Close_Button" />
    </Window.CommandBindings>

    <Border x:Name="MainWindow_Border"
            Background="{DynamicResource BackgroundColor}"
            BorderBrush="Transparent"
            BorderThickness="1"
            CornerRadius="15"
            Margin="10"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="Gray" Opacity="0.3" ShadowDepth="0" Direction="0" />
        </Border.Effect>

        <Grid Background="Transparent" RenderOptions.BitmapScalingMode="HighQuality" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Grid System -->
                <RowDefinition Height="*"/>    <!-- Levels list -->
                <RowDefinition Height="Auto"/> <!-- Section Cut -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Title Bar (Row 0) -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Button Click="Ruknbim_Link"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/RUKNBIM.SelectByRevitId;component/Resources/SelectByRevitId.png"
                               Height="28"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="BY LEVELS" 
                                   Foreground="#18263c" 
                                   FontWeight="Bold" 
                                   FontSize="15" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Style="{DynamicResource TabCloseButtonStyle}"
                        Name="CloseButton"
                        Click="Close_Button"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Grid System / Model selector (Row 1) -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Grid System:" VerticalAlignment="Center" Foreground="#18263c" FontWeight="SemiBold" FontSize="12" Margin="0,0,10,0" Grid.Column="0"/>
                <ComboBox Name="ComboModel" SelectionChanged="ComboModel_SelectionChanged" Height="28" HorizontalAlignment="Stretch" Grid.Column="1">
                </ComboBox>
            </Grid>

            <!-- Levels List Area (Row 2) -->
            <Border Grid.Row="2" Background="#F4F7FA" CornerRadius="8" BorderBrush="#E0E6ED" BorderThickness="1" Margin="0,0,0,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10">
                    <StackPanel Name="PanelLevels">
                        <!-- Levels will be loaded here dynamically -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Section Cut Group (Row 3) -->
            <GroupBox Grid.Row="3" Header="Section Cut" FontWeight="SemiBold" Foreground="#18263c" Margin="0,0,0,10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top Offset -->
                    <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                        <CheckBox Name="CheckOffsetTop" Content="Offset Top Z" IsChecked="True" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="Amount:" VerticalAlignment="Center" FontWeight="Normal" Margin="0,0,5,0"/>
                            <TextBox Name="TextOffsetTop" Text="-2" Width="60" Height="24" Padding="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Bottom Offset -->
                    <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                        <CheckBox Name="CheckOffsetBottom" Content="Offset Bottom Z" IsChecked="True" FontWeight="Normal" VerticalAlignment="Center" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="Amount:" VerticalAlignment="Center" FontWeight="Normal" Margin="0,0,5,0"/>
                            <TextBox Name="TextOffsetBottom" Text="-1" Width="60" Height="24" Padding="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Action Buttons (Row 4) -->
            <StackPanel Grid.Row="4" Margin="0,0,0,8">
                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Toggle Front/Back, Left/Right Planes" 
                        Click="TogglePlanes_Click"
                        Height="32" 
                        Margin="0,0,0,8"
                        HorizontalAlignment="Stretch"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Style="{DynamicResource ApplyButtonStyle}" 
                            Content="OK" 
                            Click="GenerateViewpoints_Click"
                            Height="32" 
                            Margin="0,0,5,0"
                            Grid.Column="0"/>
                    <Button Style="{DynamicResource ApplyButtonStyle}" 
                            Content="Cancel" 
                            Click="Close_Button"
                            Height="32" 
                            Margin="5,0,0,0"
                            Grid.Column="1"/>
                </Grid>
            </StackPanel>

            <!-- Status Bar (Row 5) -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,0">
                <TextBlock Text="Status: " Foreground="{DynamicResource SecondaryGray}" FontSize="11"/>
                <TextBlock Name="TextBlockStatus" Text="Ready..." Foreground="#1b6ece" FontWeight="SemiBold" FontSize="11"/>
            </StackPanel>

        </Grid>
    </Border>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
</Window>
