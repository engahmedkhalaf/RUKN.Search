<Window x:Class="Rukn.Navisworks.SelectByRevitId.Plugin.ModelProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="{x:Null}"
        mc:Ignorable="d"
        Width="460"
        Height="720"
        Title="Model Processing"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True"
        Style="{DynamicResource CustomWindowStyle}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="Close" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="Close" Executed="Close_Button" />
    </Window.CommandBindings>

    <Border x:Name="MainWindow_Border"
            Background="{DynamicResource BackgroundColor}"
            BorderBrush="Transparent"
            BorderThickness="1"
            CornerRadius="15"
            Margin="10"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="Gray" Opacity="0.3" ShadowDepth="0" Direction="0" />
        </Border.Effect>

        <Grid Background="Transparent" RenderOptions.BitmapScalingMode="HighQuality" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Separator -->
                <RowDefinition Height="*" />    <!-- Content Area -->
                <RowDefinition Height="Auto" /> <!-- Action Buttons -->
                <RowDefinition Height="Auto" /> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,-4,0,10">
                <Button Click="Ruknbim_Link"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter />
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/RUKNBIM.SelectByRevitId;component/Resources/SelectByRevitId.png"
                               Height="28"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="MODEL PROCESSING" 
                                   Foreground="#18263c" 
                                   FontWeight="Bold" 
                                   FontSize="16" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Style="{DynamicResource TabCloseButtonStyle}"
                        Name="CloseButton"
                        Click="Close_Button"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Separator Line -->
            <Line Grid.Row="1" 
                  Stroke="{DynamicResource MainGray}"
                  X2="1000"
                  Opacity="0.3"
                  StrokeThickness="2"
                  Margin="-20,0,-20,15" />

            <!-- Content Area -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,10,0">
                    
                    <!-- Model Source Group -->
                    <TextBlock Text="Model Source" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <StackPanel Margin="10,0,0,15">
                        <CheckBox Content="Active Model" IsChecked="True" Margin="0,0,0,8" />
                        <CheckBox Content="Selected Models" Margin="0,0,0,8" />
                        <CheckBox Content="All NWC Models" Margin="0,0,0,8" />
                        <CheckBox Content="All NWD Models" Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Reference Settings Group -->
                    <TextBlock Text="Reference Settings" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <Grid Margin="10,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Reference Level -->
                        <TextBlock Text="Reference Level:" VerticalAlignment="Center" Margin="0,0,0,8" Grid.Row="0" Grid.Column="0"/>
                        <ComboBox Name="ComboReferenceLevel" Width="180" Height="28" HorizontalAlignment="Left" Margin="0,0,0,8" Grid.Row="0" Grid.Column="1">
                            <ComboBoxItem Content="Level 00" IsSelected="True"/>
                            <ComboBoxItem Content="Level 01"/>
                            <ComboBoxItem Content="Level 02"/>
                            <ComboBoxItem Content="Basement"/>
                            <ComboBoxItem Content="Roof"/>
                        </ComboBox>

                        <!-- Offset Plane -->
                        <TextBlock Text="Offset Plane:" VerticalAlignment="Center" Margin="0,0,0,8" Grid.Row="1" Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Grid.Row="1" Grid.Column="1">
                            <TextBox Name="TextOffset" Text="0.000" Width="80" Height="28" Padding="5,2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="0,0,5,0"/>
                            <TextBlock Text="[m]" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryGray}"/>
                        </StackPanel>

                        <!-- Units -->
                        <TextBlock Text="Units:" VerticalAlignment="Top" Margin="0,5,0,0" Grid.Row="2" Grid.Column="0"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="0,5,0,0">
                            <RadioButton Content="mm" Margin="0,0,15,0" />
                            <RadioButton Content="cm" Margin="0,0,15,0" />
                            <RadioButton Content="m" IsChecked="True" Margin="0,0,15,0" />
                            <RadioButton Content="ft" />
                        </StackPanel>
                    </Grid>

                    <!-- Apply To Group -->
                    <TextBlock Text="Apply To" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <StackPanel Margin="10,0,0,15">
                        <RadioButton GroupName="ApplyToGroup" Content="All Levels" Margin="0,0,0,8" />
                        <RadioButton GroupName="ApplyToGroup" Content="Selected Levels" IsChecked="True" Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Levels Group -->
                    <TextBlock Text="Levels" FontWeight="Bold" Foreground="#18263c" FontSize="13" Margin="0,0,0,5"/>
                    <Border BorderBrush="{DynamicResource SecondaryGray}" BorderThickness="0,0,0,1" Opacity="0.3" Margin="0,0,0,10"/>
                    <Border Background="#F4F7FA" CornerRadius="8" BorderBrush="#E0E6ED" BorderThickness="1" Margin="10,0,0,10">
                        <StackPanel Margin="12,10">
                            <CheckBox Content="Basement" IsChecked="True" Margin="0,0,0,8" />
                            <CheckBox Content="Ground Floor" IsChecked="True" Margin="0,0,0,8" />
                            <CheckBox Content="Level 01" IsChecked="True" Margin="0,0,0,8" />
                            <CheckBox Content="Level 02" IsChecked="True" Margin="0,0,0,8" />
                            <CheckBox Content="Roof" IsChecked="True" />
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- Action Buttons Grid -->
            <Grid Grid.Row="3" Margin="0,15,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Read Models" 
                        Click="ReadModels_Click"
                        Height="34" 
                        Margin="0,0,5,8"
                        Grid.Row="0" Grid.Column="0"/>
                
                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Generate Viewpoints" 
                        Click="GenerateViewpoints_Click"
                        Height="34" 
                        Margin="5,0,0,8"
                        Grid.Row="0" Grid.Column="1"/>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Save Viewpoints" 
                        Click="SaveViewpoints_Click"
                        Height="34" 
                        Margin="0,0,5,0"
                        Grid.Row="1" Grid.Column="0"/>

                <Button Style="{DynamicResource ApplyButtonStyle}" 
                        Content="Export Data" 
                        Click="ExportData_Click"
                        Height="34" 
                        Margin="5,0,0,0"
                        Grid.Row="1" Grid.Column="1"/>
            </Grid>

            <!-- Status Bar -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Status: " Foreground="{DynamicResource SecondaryGray}" FontSize="12"/>
                <TextBlock Name="TextBlockStatus" Text="Ready..." Foreground="#1b6ece" FontWeight="SemiBold" FontSize="12"/>
            </StackPanel>

        </Grid>
    </Border>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="./Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
</Window>
